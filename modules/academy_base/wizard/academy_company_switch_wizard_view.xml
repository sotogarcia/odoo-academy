<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <record id="view_academy_copmany_switch_wizard_form" model="ir.ui.view">
            <field name="name">Company switch wizard</field>
            <field name="model">academy.company.switch.wizard</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="Switch company" create="0" delete="0" edit="1">
                    <header>
                        <button name="switch_company" type="object"
                                string="Switch" class="oe_highlight" />
                    </header>

                    <group col="2">
                        <field name="company_id" class="oe_field_company_id" />
                    </group>
                </form>
            </field>
        </record>


        <record id="action_swich_company_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Swich company</field>
            <field name="res_model">academy.company.switch.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="binding_model_id" ref="academy_base.model_academy_training_action" />
            <field name="binding_view_types">list,form</field>
            <field name="groups_id" eval="[(4, ref('base.group_multi_company'))]"/>
        </record>

    </data>
</openerp>