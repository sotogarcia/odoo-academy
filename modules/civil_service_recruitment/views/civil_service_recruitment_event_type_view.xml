<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <!-- VIEWS: "Event types"

            - Model·········: civil.service.recruitment.event.type
            - _rec_name·····: name
            - Domain········: []
            - Context·······: {}
            - Parent menu ··: menu_civil_service_settings
            - View priority·: 16    Sequence····: 10
            - Action help···: There is no any event type
        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

        <!-- Tree view for "civil.service.recruitment.event.type" -->
        <record id="view_civil_service_recruitment_event_type_tree" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.event.type.tree</field>
            <field name="model">civil.service.recruitment.event.type</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <tree string="civil_service_recruitment_event_type_tree" create="1" delete="1" edit="1">
                    <field name="sequence" class="oe_field_sequence" widget="handle" />
                    <field name="name" class="oe_field_name" />
                    <field name="active" class="oe_field_active" />
                    <field name="is_stage" class="oe_field_is_stage" />
                    <field name="fold" class="oe_field_fold" />
                    <field name="related_field_id" class="oe_field_related_field" />
                    <field name="description" class="oe_field_description" />
                </tree>
            </field>
        </record>

        <!-- Form view for "civil.service.recruitment.event.type" -->
        <record id="view_civil_service_recruitment_event_type_form" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.event.type.form</field>
            <field name="model">civil.service.recruitment.event.type</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="civil_service_recruitment_event_type_form" create="1" delete="1" edit="1">
                    <sheet>
                        <field name="active" invisible="1" />

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>

                        <div class="oe_button_box" name="button_box" />

                        <div class="oe_title">
                            <field name="active" class="oe_field_active" invisible="1" />
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" class="oe_field_name"
                                    placeholder="Enter new name" />
                            </h1>
                        </div>
                        <group col="2">
                            <field name="is_stage" class="oe_field_is_stage" />
                            <field name="related_field_id" class="oe_field_related_field" />
                            <field name="fold" class="oe_field_fold" />
                            <field name="description" class="oe_field_description" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view for "civil.service.recruitment.event.type" -->
        <record id="view_civil_service_recruitment_event_type_search" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.event.type.search</field>
            <field name="model">civil.service.recruitment.event.type</field>
            <field name="type">search</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <search string="civil_service_recruitment_event_type_search">
                    <field name="name" />

                    <separator/>

                    <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- Main window action for model.name -->
        <record id="action_civil_service_recruitment_event_type_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Event types</field>
            <field name="res_model">civil.service.recruitment.event.type</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_civil_service_recruitment_event_type_search" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new event types
                </p><p>
                    There are no event types yet
                </p>
            </field>
        </record>

    </data>
</openerp>
