<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <!-- VIEWS: "Vacancy"

            - Model·········: civil.service.recruitment.vacancy.position
            - _rec_name·····: name
            - Domain········: []
            - Context·······: {}
            - Parent menu ··: civil_service_recruitment.menu_tendering_top
            - View priority·: 16    Sequence····: 10
            - Action help···: There is no any vacancy yet
        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

        <!-- Tree view for "civil.service.recruitment.vacancy.position" -->
        <record id="view_civil_service_recruitment_vacancy_tree" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.vacancy.position.tree</field>
            <field name="model">civil.service.recruitment.vacancy.position</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <tree string="civil_service_recruitment_vacancy_tree" create="1" delete="1" edit="1">
                    <field name="sequence" class="od_field_sequence" widget="handle" />
                    <field name="vacancy_type_id" class="oe-field-civil-service-recruitment-vacancy-type" />
                    <field name="name" class="oe_field_name" required="0" string="Name" />
                    <field name="quantity" class="oe_field_total_of_vacancies" />
                </tree>
            </field>
        </record>

        <record id="view_civil_service_recruitment_vacancy_tree_x2many" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.vacancy.position.tree</field>
            <field name="model">civil.service.recruitment.vacancy.position</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="25" />
            <field name="active" eval="True" />
            <field name="inherit_id" ref="civil_service_recruitment.view_civil_service_recruitment_vacancy_tree" />
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="editable">bottom</attribute>
                </xpath>
            </field>
        </record>

        <!-- Form view for "civil.service.recruitment.vacancy.position" -->
        <record id="view_civil_service_recruitment_vacancy_form" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.vacancy.position.form</field>
            <field name="model">civil.service.recruitment.vacancy.position</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="civil_service_recruitment_vacancy_form" create="1" delete="1" edit="1">
                    <sheet>
                        <field name="active" invisible="1" />

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>

                        <div class="oe_button_box" name="button_box" />

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" class="oe_field_name"
                                    placeholder="Enter new name" />
                            </h1>
                        </div>

                        <group col="2" string="Description">
                            <field name="process_id"
                                class="oe_field_process_id" />
                            <field name="vacancy_type_id"
                                class="oe_field_vacancy_type_id" />
                            <field name="quantity" class="oe_field_quantity"
                                placeholder="Enter new quantity" />
                            <field name="description" class="oe_field_description" nolabel="1"
                                placeholder="Enter new description" colspan="2" />
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view for "civil.service.recruitment.vacancy.position" -->
        <record id="view_civil_service_recruitment_vacancy_search" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.vacancy.position.search</field>
            <field name="model">civil.service.recruitment.vacancy.position</field>
            <field name="type">search</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <search string="civil_service_recruitment_vacancy_search">
                    <field name="name" />
                    <field name="vacancy_type_id" />
                    <field name="quantity" />
                    <field name="process_id" />

                    <separator/>

                    <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- Main window action for model.name -->
        <record id="action_vacancys_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Vacancies</field>
            <field name="res_model">civil.service.recruitment.vacancy.position</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_civil_service_recruitment_vacancy_search" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new vacancies
                </p><p>
                    There are no vacancies yet
                </p>
            </field>
        </record>


        <!-- Main menu for model.name -->
        <record id="menu_vacancys" model="ir.ui.menu" >
            <field name="name">Vacancies</field>
            <field name="sequence" eval="10" />
            <field name="action" ref="action_vacancys_act_window" />
            <field name="parent_id" ref="menu_civil_service_settings" />
        </record>

    </data>
</openerp>
