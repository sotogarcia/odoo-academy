<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <!-- VIEWS: "Vacancy group"

            - Model·········: civil.service.recruitment.employment.group
            - _rec_name·····: name
            - Domain········: []
            - Context·······: {}
            - Parent menu ··: base.menu_custom
            - View priority·: 16    Sequence····: 10
            - Action help···: There is no any group yet
        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

        <!-- Tree view for "civil.service.recruitment.employment.group" -->
        <record id="view_civil_service_recruitment_employment_group_tree" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.employment.group.tree</field>
            <field name="model">civil.service.recruitment.employment.group</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <tree string="civil_service_recruitment_employment_group_tree" editable="bottom" create="1" delete="1" edit="1">
                    <field name="name" class="oe_field_name" />
                    <!-- <field name="qualification_level_id" class="oe_field_qualification_level_id" /> -->
                    <field name="description" class="oe_field_description" />
                </tree>
            </field>
        </record>

        <!-- Form view for "civil.service.recruitment.employment.group" -->
        <record id="view_civil_service_recruitment_employment_group_form" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.employment.group.form</field>
            <field name="model">civil.service.recruitment.employment.group</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="civil_service_recruitment_employment_group_form" create="1" delete="1" edit="1">
                    <sheet>
                        <field name="active" invisible="1" />

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>

                        <div class="oe_button_box" name="button_box" />

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" class="oe_field_name"
                                    placeholder="Enter new name" />
                            </h1>
                        </div>
                        <group col="2">
                            <!-- <field name="qualification_level_id" class="oe_field_qualification_level_id" /> -->
                            <field name="description" class="oe_field_description"
                                placeholder="Enter new description" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view for "civil.service.recruitment.employment.group" -->
        <record id="view_civil_service_recruitment_employment_group_search" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.employment.group.search</field>
            <field name="model">civil.service.recruitment.employment.group</field>
            <field name="type">search</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <search string="civil_service_recruitment_employment_group_search">
                    <field name="name" />
                    <!-- <field name="qualification_level_id" /> -->

                    <separator/>

                    <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- Main window action for model.name -->
        <record id="action_employment_position_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Employment groups</field>
            <field name="res_model">civil.service.recruitment.employment.group</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_civil_service_recruitment_employment_group_search" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new employment groups
                </p><p>
                    There are no employment groups yet
                </p>
            </field>
        </record>

        <!-- Main menu for model.name -->
        <record id="menu_employment_group" model="ir.ui.menu" >
            <field name="name">Employment groups</field>
            <field name="sequence" eval="10" />
            <field name="action" ref="action_employment_position_act_window" />
            <field name="parent_id" ref="menu_civil_service_recruitment_top" />
            <field name="groups_id" eval="[(4, ref('civil_service_recruitment.civil_service_recruitment_manager'))]" />
        </record>

    </data>
</openerp>
