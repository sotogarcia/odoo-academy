<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <!-- VIEWS: "Vacancy Type"

            - Model·········: civil.service.recruitment.public.corps
            - _rec_name·····: name
            - Domain········: []
            - Context·······: {}
            - Parent menu ··: menu_civil_service_settings
            - View priority·: 16    Sequence····: 10
            - Action help···: There is no any corps yet
        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

        <!-- Tree view for "civil.service.recruitment.public.corps" -->
        <record id="view_civil_service_recruitment_public_corps_tree" model="ir.ui.view">
            <field name="name">view.civil_service_recruitment_public_corps_tree</field>
            <field name="model">civil.service.recruitment.public.corps</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <tree string="civil_service_recruitment_public_corps_tree" create="1" delete="1" edit="1">
                    <field name="name" />
                    <field name="group_id" class="oe_field_employment_group_id" />
                    <field name="specialization_id" class="oe_field_required_specialization_id" />
                    <field name="description" />
                </tree>
            </field>
        </record>

        <!-- Form view for "civil.service.recruitment.public.corps" -->
        <record id="view_civil_service_recruitment_public_corps_form" model="ir.ui.view">
            <field name="name">view.civil_service_recruitment_public_corps_form</field>
            <field name="model">civil.service.recruitment.public.corps</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="civil_service_recruitment_public_corps_form" create="1" delete="1" edit="1">
                    <sheet>
                        <field name="active" invisible="1" />

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>

                        <div class="oe_button_box" name="button_box" />

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" class="oe_field_name"
                                    placeholder="Enter new name" />
                            </h1>
                        </div>
                        <group col="2">
                            <field name="group_id" class="oe_field_employment_group_id" />
                            <field name="specialization_id" class="oe_field_required_specialization_id" />
                            <field name="description" class="oe_field_description"
                                placeholder="Enter new description" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view for "civil.service.recruitment.public.corps" -->
        <record id="view_civil_service_recruitment_public_corps_search" model="ir.ui.view">
            <field name="name">view.civil_service_recruitment_public_corps_search</field>
            <field name="model">civil.service.recruitment.public.corps</field>
            <field name="type">search</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <search string="civil_service_recruitment_public_corps_search">
                    <field name="name" />
                    <field name="group_id" />
                    <field name="specialization_id" />

                    <separator/>

                    <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- Main window action for model.name -->
        <record id="action_civil_service_recruitment_public_corps_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Job corps</field>
            <field name="res_model">civil.service.recruitment.public.corps</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_civil_service_recruitment_public_corps_search" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new employees corps
                </p><p>
                    There are no employees corps yet
                </p>
            </field>
        </record>

    </data>
</openerp>
