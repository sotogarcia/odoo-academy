<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">

        <!-- VIEWS: "Vacancy class"

            - Model·········: civil.service.recruitment.hiring.type
            - _rec_name·····: name
            - Domain········: []
            - Context·······: {}
            - Parent menu ··: base.menu_custom
            - View priority·: 16    Sequence····: 10
            - Action help···: There is no any class yet
        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

        <!-- Tree view for "civil.service.recruitment.hiring.type" -->
        <record id="view_civil_service_recruitment_hiring_type_tree" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.hiring.type.tree</field>
            <field name="model">civil.service.recruitment.hiring.type</field>
            <field name="type">tree</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <tree string="civil_service_recruitment_hiring_type_tree" editable="bottom" create="1" delete="1" edit="1">
                    <field name="name" class="oe_field_name" string="Name"
                        placeholder="Enter new name" />
                    <field name="description" class="oe_field_description"
                        placeholder="Enter new description" />
                </tree>
            </field>
        </record>

        <!-- Form view for "civil.service.recruitment.hiring.type" -->
        <record id="view_civil_service_recruitment_hiring_type_form" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.hiring.type.form</field>
            <field name="model">civil.service.recruitment.hiring.type</field>
            <field name="type">form</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <form string="civil_service_recruitment_hiring_type_form" create="1" delete="1" edit="1">
                    <sheet>
                        <field name="active" invisible="1" />

                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>

                        <div class="oe_button_box" name="button_box" />

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name="name" class="oe_field_name"
                                    placeholder="Enter new name" />
                            </h1>
                        </div>
                        <group col="2">
                            <field name="description" class="oe_field_description"
                                placeholder="Enter new description" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view for "civil.service.recruitment.hiring.type" -->
        <record id="view_civil_service_recruitment_hiring_type_search" model="ir.ui.view">
            <field name="name">view.civil.service.recruitment.hiring.type.search</field>
            <field name="model">civil.service.recruitment.hiring.type</field>
            <field name="type">search</field>
            <field name="mode">primary</field>
            <field name="priority" eval="16" />
            <field name="active" eval="True" />
            <field name="arch" type="xml">
                <search string="civil_service_recruitment_hiring_type_search">
                    <field name="name" />

                    <separator/>

                    <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- Main window action for model.name -->
        <record id="action_hiring_type_act_window" model="ir.actions.act_window">
            <field name="type">ir.actions.act_window</field>
            <field name="name">Hiring types</field>
            <field name="res_model">civil.service.recruitment.hiring.type</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_civil_service_recruitment_hiring_type_search" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new hiring types
                </p><p>
                    There are no hiring types yet
                </p>
            </field>
        </record>

        <!-- Main menu for model.name -->
        <record id="menu_hiring_type" model="ir.ui.menu" >
            <field name="name">Hiring types</field>
            <field name="sequence" eval="10" />
            <field name="action" ref="action_hiring_type_act_window" />
            <field name="parent_id" ref="menu_civil_service_settings" />
            <field name="groups_id" eval="[(4, ref('civil_service_recruitment.civil_service_recruitment_group_manager'))]" />
        </record>

    </data>
</openerp>
