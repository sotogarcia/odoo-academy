<?xml version="1.0" encoding="UTF-8"?>

<openerp>
    <data noupdate="0">


        <!-- Add the autonomous community field to the public administration form view -->
        <record id="view_civil_service_recruitment_public_administration_form" model="ir.ui.view">
            <field name="name">civil.service.recruitment.public.administration.form</field>
            <field name="model">civil.service.recruitment.public.administration</field>
            <field name="type">form</field>
            <field name="mode">extension</field>
            <field name="priority" eval="26" />
            <field name="active" eval="True" />
            <field name="inherit_id" ref="civil_service_recruitment.view_civil_service_recruitment_public_administration_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='country_id']" position="before">
                    <field name="region_id" class="oe_field_region_id"
                        placeholder="Autonomous community" />
                </xpath>
            </field>
        </record>


    </data>
</openerp>
